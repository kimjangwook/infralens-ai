# Django
DJANGO_SECRET_KEY=change-me-before-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# SQLite path. Use an absolute path in Docker if you mount a volume.
INFRALENS_DB_PATH=db.sqlite3

# Keep raw log storage disabled. Current scanners store summaries and samples only.
INFRALENS_STORE_RAW_LOGS=false

# AI briefing generation. Toggle the feature here; configure providers, models,
# and API keys in the app under Settings -> AI providers (stored encrypted).
INFRALENS_AI_ENABLED=true

# Legacy: only read once by the upgrade migration to import an existing key.
# New installs should add providers in the app UI instead.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini-2026-03-17
