# Django
DJANGO_SECRET_KEY=change-me-before-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# SQLite path. Use an absolute path in Docker if you mount a volume.
INFRALENS_DB_PATH=db.sqlite3

# Keep raw log storage disabled. Current scanners store summaries and samples only.
INFRALENS_STORE_RAW_LOGS=false

# AI briefing generation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini-2026-03-17
